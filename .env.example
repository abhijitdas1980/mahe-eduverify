# ===========================================================
# EduVerify backend — environment variables
# Copy this file to ".env" and fill in the values.
# NEVER commit the real .env file to git.
# ===========================================================

# --- Server ---
PORT=8080
NODE_ENV=production

# Allowed browser origin for the frontend.
# Use "*" only for local testing. In production set it to your real URL,
# e.g. https://eduverify.onrender.com
CORS_ORIGIN=*

# --- Security ---
# A long random string used to sign login tokens (JWT).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret
# How long a login stays valid.
JWT_EXPIRES_IN=12h

# --- PostgreSQL ---
# On Render this is provided automatically as DATABASE_URL.
# Locally use something like: postgres://user:pass@localhost:5432/eduverify
DATABASE_URL=postgres://user:password@localhost:5432/eduverify

# --- Cloudinary (secure document storage) ---
# Create a free account at https://cloudinary.com and copy these
# from your dashboard (Settings -> API Keys).
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- Seed defaults (used only by "npm run setup") ---
# The first verification-cell staff account.
# Used only when ADM-001 is first created — changing this later does NOT update an existing password.
# To apply a new password to an existing admin on Render, either:
#   1) Set SEED_ADMIN_SYNC_PASSWORD=true, redeploy once, then remove that variable, OR
#   2) Run: npm run reset-admin  (with DATABASE_URL + SEED_ADMIN_PASSWORD set)
SEED_ADMIN_ID=ADM-001
SEED_ADMIN_NAME=Verification Cell Admin
SEED_ADMIN_PASSWORD=ChangeMe@2026
# SEED_ADMIN_SYNC_PASSWORD=true
