# ===========================================================
# EduVerify backend — environment variables
# Copy this file to ".env" and fill in the values.
# NEVER commit the real .env file to git.
# ===========================================================

# --- Server ---
PORT=8080
NODE_ENV=production

# Allowed browser origin for the frontend.
# In production set it to your exact Azure URL, e.g.
# https://eduverify.yourcollege.edu
CORS_ORIGIN=*

# --- Security ---
# A long random string used to sign login tokens (JWT).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=12h

# --- PostgreSQL (metadata: students, documents, schedule, audit) ---
# Azure: postgresql://user:pass@psql-eduverifyprod.postgres.database.azure.com:5432/eduverify?sslmode=require
DATABASE_URL=postgres://user:password@localhost:5432/eduverify
PG_POOL_MAX=25

# --- Document storage (Azure Blob — production) ---
STORAGE_PROVIDER=azure
AZURE_STORAGE_ACCOUNT_NAME=steduverifyprod
AZURE_STORAGE_CONTAINER=eduverify-documents
AZURE_STORAGE_SAS_EXPIRY_MINUTES=60
# Local dev / fallback only — production uses Managed Identity on App Service:
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_STORAGE_ACCOUNT_KEY=...

# --- Legacy Cloudinary (only if STORAGE_PROVIDER=cloudinary) ---
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# --- Database bootstrap ---
AUTO_SETUP=true

# --- Seed defaults (used by "npm run setup" on deploy) ---
SEED_ADMIN_ID=ADM-001
SEED_ADMIN_NAME=Verification Cell Admin
SEED_ADMIN_PASSWORD=ChangeMe@2026

# --- Email notifications (MAHE Microsoft 365) ---
# Sends to student + parent when a document is rejected; also Communication Center.
#
# Preferred: Microsoft Graph OAuth2 (Modern Auth — no mailbox password)
MAIL_PROVIDER=auto
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
SMTP_USER=admissions.maheblr@manipal.edu
SMTP_FROM=MAHE Admissions <admissions.maheblr@manipal.edu>
#
# Legacy fallback: SMTP password (Gmail app password or M365 basic auth if enabled)
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_PASS=
#
# Production requires SMTP_USER plus either Graph OAuth2 vars above OR SMTP_PASS.
NOTIFY_EMAIL_ENABLED=true
PORTAL_URL=https://maheblreduverify.manipal.edu
