# MAHE UAT — fill in and save as .env.azure-uat (never commit)
# cp mahe-uat.env.example .env.azure-uat

AZURE_RG=REPLACE_WITH_UAT_RESOURCE_GROUP
AZURE_WEBAPP=MAHE-CI-DOC-UAT-APP01

NODE_ENV=production
PORT=8080
AUTO_SETUP=true
STORAGE_PROVIDER=azure

AZURE_STORAGE_ACCOUNT_NAME=mahecidocuatstgacct01
AZURE_STORAGE_CONTAINER=eduverify-documents
# Paste UAT storage connection string from Key Vault / secure email:
AZURE_STORAGE_CONNECTION_STRING=

# Password must be URL-encoded in DATABASE_URL (@ -> %40)
DATABASE_URL=postgresql://psqladmin:REPLACE_URL_ENCODED_PASSWORD@mahe-ci-doc-uat-psqlsvr01.postgres.database.azure.com:5432/eduverify?sslmode=require

JWT_SECRET=
JWT_EXPIRES_IN=12h

SEED_ADMIN_ID=ADM-001
SEED_ADMIN_NAME=Verification Cell Admin
SEED_ADMIN_PASSWORD=

CORS_ORIGIN=https://mahe-ci-doc-uat-app01-e4g0fzdeh8e8ehe6.centralindia-01.azurewebsites.net
PG_POOL_MAX=25

# --- Email (MAHE M365 — document rejection alerts to student + parent) ---
# SMTP_PASS is MANDATORY — production/UAT will not start without it.
NOTIFY_EMAIL_ENABLED=true
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=admissions.maheblr@manipal.edu
SMTP_PASS=replace-with-m365-mailbox-or-app-password
SMTP_FROM=MAHE Admissions <admissions.maheblr@manipal.edu>
PORTAL_URL=https://mahe-ci-doc-uat-app01-e4g0fzdeh8e8ehe6.centralindia-01.azurewebsites.net
