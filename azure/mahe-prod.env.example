# MAHE Production — fill in and save as .env.azure-prod (never commit)
# cp mahe-prod.env.example .env.azure-prod

AZURE_RG=REPLACE_WITH_PRD_RESOURCE_GROUP
AZURE_WEBAPP=MAHE-CI-DOC-PRD-APP01

NODE_ENV=production
PORT=8080
AUTO_SETUP=true
STORAGE_PROVIDER=azure

AZURE_STORAGE_ACCOUNT_NAME=mahecidocprdstgacct01
AZURE_STORAGE_CONTAINER=eduverify-documents
# Prod storage connection string OR leave blank if using Managed Identity only:
AZURE_STORAGE_CONNECTION_STRING=

# Password must be URL-encoded in DATABASE_URL (@ -> %40)
DATABASE_URL=postgresql://psqladmin:REPLACE_URL_ENCODED_PASSWORD@mahe-ci-doc-prd-psqlsvr01.postgres.database.azure.com:5432/eduverify?sslmode=require

# Use NEW secrets for production (do not reuse UAT JWT/admin password)
JWT_SECRET=
JWT_EXPIRES_IN=12h

SEED_ADMIN_ID=ADM-001
SEED_ADMIN_NAME=Verification Cell Admin
SEED_ADMIN_PASSWORD=

# Copy exact Default domain from Azure Portal → MAHE-CI-DOC-PRD-APP01 → Overview
# Until custom domain is live, use the *.azurewebsites.net URL (not maheblreduverify.manipal.edu)
CORS_ORIGIN=https://REPLACE-WITH-PRD-DEFAULT-DOMAIN.azurewebsites.net
PG_POOL_MAX=25

NOTIFY_EMAIL_ENABLED=true
MAIL_PROVIDER=auto
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
SMTP_USER=admissions.maheblr@manipal.edu
SMTP_FROM=MAHE Admissions <admissions.maheblr@manipal.edu>
PORTAL_URL=https://REPLACE-WITH-PRD-DEFAULT-DOMAIN.azurewebsites.net
